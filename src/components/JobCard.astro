---
interface Props {
  id: string;
  title: string;
  company: string;
  location: string;
  salary_range?: string;
  gemini_summary: string;
  tags: string[];
}

const { id, title, company, location, salary_range, gemini_summary, tags } =
  Astro.props;
---

<a href={`/jobs/${id}`} class="card p-6 block hover:shadow-lg">
  <div class="flex flex-col gap-3">
    <div>
      <h3 class="text-lg font-bold text-slate-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400">
        {title}
      </h3>
      <p class="text-sm text-slate-600 dark:text-slate-400">
        {company} • {location}
      </p>
    </div>

    {salary_range && (
      <p class="text-sm font-medium text-green-600 dark:text-green-400">
        {salary_range}
      </p>
    )}

    <p class="text-sm text-slate-700 dark:text-slate-300 line-clamp-2">
      {gemini_summary}
    </p>

    <div class="flex flex-wrap gap-2 pt-2">
      {tags.slice(0, 3).map((tag) => (
        <span class="badge">{tag}</span>
      ))}
      {tags.length > 3 && (
        <span class="inline-block px-2 py-1 text-xs text-slate-500">
          +{tags.length - 3}
        </span>
      )}
    </div>
  </div>
</a>
