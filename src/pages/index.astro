---
import BaseLayout from "../layouts/BaseLayout.astro";
import JobCard from "../components/JobCard.astro";
import SearchFilter from "../components/SearchFilter.astro";
import { createClient } from "@supabase/supabase-js";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const supabase = createClient(supabaseUrl, supabaseAnonKey);

// Fetch jobs from Supabase
let jobs = [];
let allTags = new Set<string>();
let error = null;

try {
  const { data, error: fetchError } = await supabase
    .from("jobs")
    .select("*")
    .eq("is_relevant", true)
    .order("created_at", { ascending: false })
    .limit(100);

  if (fetchError) {
    error = fetchError.message;
    console.error("Error fetching jobs:", fetchError);
  } else if (data) {
    jobs = data;
    // Collect all unique tags
    data.forEach((job) => {
      if (job.tags && Array.isArray(job.tags)) {
        job.tags.forEach((tag) => allTags.add(tag));
      }
    });
  }
} catch (e) {
  error = "Failed to connect to database";
  console.error("Database connection error:", e);
}

const tagsArray = Array.from(allTags).sort();
---

<BaseLayout title="AI Job Board - Find Your Dream Automation Role">
  <div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-950 dark:to-slate-900">
    <!-- Header -->
    <header class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="text-center">
          <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-2">
            AI Job Board
          </h1>
          <p class="text-lg text-slate-600 dark:text-slate-400">
            Discover automation roles for Make, Zapier, n8n & LangChain experts
          </p>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Search & Filters -->
      <SearchFilter allTags={tagsArray} />

      <!-- Error Message -->
      {error && (
        <div class="bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-6">
          <p class="text-red-800 dark:text-red-200">
            <strong>Connection Error:</strong> {error}
          </p>
          <p class="text-sm text-red-700 dark:text-red-300 mt-2">
            Make sure your Supabase credentials are correct in .env.local
          </p>
        </div>
      )}

      <!-- Jobs Grid -->
      {jobs.length > 0 ? (
        <div
          id="jobs-container"
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
        >
          {jobs.map((job) => (
            <div
              data-job-card
              data-title={job.title}
              data-company={job.company}
              data-location={job.location || "Remote"}
              data-tags={job.tags?.join(",") || ""}
            >
              <JobCard
                id={job.id}
                title={job.title}
                company={job.company}
                location={job.location || "Remote"}
                salary_range={job.salary_range}
                gemini_summary={
                  job.gemini_summary ||
                  `Join ${job.company} for ${job.title.toLowerCase()}`
                }
                tags={job.tags || ["Automation"]}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="bg-white dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800 p-12 text-center">
          <p class="text-slate-600 dark:text-slate-400 mb-2">
            No jobs yet. The scraper will start fetching jobs automatically!
          </p>
          <p class="text-sm text-slate-500 dark:text-slate-500">
            Check back later or run: <code class="bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded">npm run scrape</code>
          </p>
        </div>
      )}
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-200 dark:border-slate-800 mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 text-center text-slate-600 dark:text-slate-400">
        <p>
          ✨ AI Job Board - Discovering the best roles for automation experts
        </p>
      </div>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen,
      Ubuntu, Cantarell, sans-serif;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  code {
    font-family: "Monaco", "Menlo", monospace;
    font-size: 0.875em;
  }
</style>
